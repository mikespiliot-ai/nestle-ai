# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CoinGecko (Pro API optional)
COINGECKO_API_KEY=your_coingecko_api_key_here

# NewsAPI
NEWSAPI_KEY=your_newsapi_key_here

# Twitter / X API v2
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Glassnode On-Chain Data
GLASSNODE_API_KEY=your_glassnode_api_key_here

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=your_fred_api_key_here

# Binance Testnet (optional — enables live testnet trading)
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_binance_testnet_secret_here
